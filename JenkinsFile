pipeline {
    agent any

    stages {
        stage('Run SDLC Python Code') {
            steps {
                echo "Running SDLC Program"

                sh '''
python3 - << 'EOF'
print("=== SOFTWARE DEVELOPMENT LIFE CYCLE (SDLC) ===\\n")

print("1. REQUIREMENT ANALYSIS")
print(" - Gathering requirements")
print(" - Understanding client needs")
print(" - Identifying project goals\\n")

print("2. PLANNING")
print(" - Preparing project plan")
print(" - Estimating cost, time, resources")
print(" - Risk analysis\\n")

print("3. SYSTEM DESIGN")
print(" - Designing architecture")
print(" - Database design")
print(" - UI/UX design\\n")

print("4. DEVELOPMENT")
print(" - Writing code")
print(" - Implementing features")
print(" - Integrating modules\\n")

print("5. TESTING")
print(" - Running test cases")
print(" - Finding defects")
print(" - Fixing bugs\\n")

print("6. DEPLOYMENT")
print(" - Deploying to server")
print(" - Releasing to users")
print(" - Production rollout\\n")

print("7. MAINTENANCE")
print(" - Monitoring system")
print(" - Fixing issues")
print(" - Updating and enhancing software\\n")

print("=== SDLC PROCESS COMPLETED ===")
EOF
'''
            }
        }
    }
}
``
